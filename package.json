{
	"name": "apartment-access",
	"private": true,
	"workspaces": {
		"packages": [
			"apps/*",
			"packages/*"
		],
		"catalog": {
			"dotenv": "^17.2.2",
			"zod": "^4.1.13",
			"typescript": "^5",
			"convex": "^1.31.2",
			"better-auth": "1.4.7",
			"@convex-dev/better-auth": "^0.10.6"
		}
	},
	"type": "module",
	"scripts": {
		"check": "biome check --write .",
		"dev": "turbo dev",
		"build": "turbo build",
		"check-types": "turbo check-types",
		"dev:native": "turbo -F native dev",
		"dev:web": "turbo -F web dev",
		"dev:server": "turbo -F @apartment-access/backend dev",
		"dev:setup": "turbo -F @apartment-access/backend dev:setup"
	},
	"dependencies": {
		"dotenv": "catalog:",
		"zod": "catalog:"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.10",
		"turbo": "^2.7.1",
		"typescript": "catalog:"
	},
	"packageManager": "bun@1.3.5"
}
